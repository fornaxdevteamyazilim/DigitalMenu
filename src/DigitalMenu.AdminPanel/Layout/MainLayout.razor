@inherits LayoutComponentBase

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-3">ReXXtra - Dijital Menü SaaS</MudText>
        <MudSpacer />
        <MudChip T="string" Color="Color.Success" Variant="Variant.Text">Aktif Restoran: Lezzet Durağı</MudChip>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2">
        <MudNavMenu>
            <MudText Typo="Typo.h6" Class="px-4 py-3">Yönetim</MudText>
            <MudNavLink Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard" Href="/">Özet Paneli</MudNavLink>
            <MudNavLink Icon="@Icons.Material.Filled.TableBar" Href="/tables">Masa & QR Yönetimi</MudNavLink>
            <MudNavLink Icon="@Icons.Material.Filled.RestaurantMenu" Href="/menu">Menü Ürünleri</MudNavLink>
            <MudNavLink Icon="@Icons.Material.Filled.Sync" Href="/integration">Trendyol Entegrasyonu</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4 pt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}
